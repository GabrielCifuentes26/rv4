{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "archive/**",
      "database/**",
      "memory/**",
      "tools/**",
      "*.bat",
      "*.log",
      "*.md",
      "node_modules/**",
      "package*.json"
    ],
    "rewrites": [],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
